rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Función para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Reglas para la colección de transacciones
    match /transactions/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para la colección de responsables
    match /responsibles/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para la colección de asignaciones
    match /assignments/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para la colección de cuentas
    match /accounts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para la colección de usuarios
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para la colección de registro de actividades
    match /activityLog/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para la colección de registros de importación
    match /importLogs/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para cuentas de propietarios
    match /ownerAccounts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para saldos mensuales de propietarios
    match /ownerMonthlyBalances/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para lotes de pago
    match /paymentBatches/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para items de lotes de pago
    match /paymentBatchItems/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reglas para cualquier otra colección
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}